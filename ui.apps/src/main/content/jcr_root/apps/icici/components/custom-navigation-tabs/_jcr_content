<sly data-sly-use.model="com.aem.icici.core.models.SavingsHeaderHeroBannerModel"/>

<div class="offer-cards-container">
    <h2>${model.title}</h2>
    <p>${model.description}</p>

    <div class="cards-wrapper">
        <sly data-sly-list.card="${model.cards} ">
            <div class="card">
                <img src="${card.image @ context='uri'}" alt="${card.cardTitle}" />
                <h3>${card.cardTitle}</h3>
            </div>
        </sly>
    </div>

    <div class="apply-now-button">
        <button>${model.buttonText}</button>
    </div>
</div>





<style>
.offer-cards-container {
  background: #fff5ee;
  padding: 60px 20px 80px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.offer-cards-container h2 {
  font-size: 32px;
  font-weight: 700;
  color: #2c2c2c;
  margin-bottom: 10px;
}

.offer-cards-container p {
  font-size: 28px;
  font-weight: 600;
  color: #ff7a00;
  margin-bottom: 50px;
}

.offer-cards-container .cards-wrapper {
  position: relative;
  width: 100%;
  max-width: 1200px;
  height: 360px;
  margin: 0 auto 40px;
}

.offer-cards-container .card {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 200px;
  height: 280px;
  background: #ffffff;
  border-radius: 20px;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
  transform-origin: center center;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15px;
  transition: transform 0.4s ease, box-shadow 0.4s ease;
  will-change: transform;
}

/* Inside Card */
.offer-cards-container .card img {
  width: 100%;
  height: 150px;
  object-fit: contain;
  border-radius: 12px;
  margin-bottom: 10px;
}

.offer-cards-container .card h3 {
  font-size: 16px;
  font-weight: 600;
  color: #2c2c2c;
  margin-top: auto;
  text-align: center;
}

/* Better Card Arc Placement (More Spread) */
.offer-cards-container .card:nth-child(1) {
  transform: translate(-300px, -60px) rotate(-10deg);
}
.offer-cards-container .card:nth-child(2) {
  transform: translate(-150px, -140px) rotate(-5deg);
}
.offer-cards-container .card:nth-child(3) {
  transform: translate(0px, -170px) rotate(0deg);
}
.offer-cards-container .card:nth-child(4) {
  transform: translate(150px, -140px) rotate(5deg);
}
.offer-cards-container .card:nth-child(5) {
  transform: translate(300px, -60px) rotate(10deg);
}

/* Hover Animation */
.offer-cards-container .card:hover {
  transform: translateY(-20px) scale(1.03);
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.2);
  z-index: 2;
}

/* Apply Now Button */
.offer-cards-container .apply-now-button {
  margin-top: 20px;
}

.offer-cards-container .apply-now-button button {
  background-color: #ff7a00;
  color: #ffffff;
  font-size: 20px;
  font-weight: 700;
  border: none;
  padding: 14px 50px;
  border-radius: 40px;
  cursor: pointer;
  transition: background-color 0.3s ease;
}

.offer-cards-container .apply-now-button button:hover {
  background-color: #e56a00;
}

</style>



