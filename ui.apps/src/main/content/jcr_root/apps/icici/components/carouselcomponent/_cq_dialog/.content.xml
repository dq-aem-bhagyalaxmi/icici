<?xml version="1.0" encoding="UTF-8"?>
<jcr:root
    xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    xmlns:cq="http://www.day.com/jcr/cq/1.0"
    xmlns:jcr="http://www.jcp.org/jcr/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Custom Carousel Dialog"
    sling:resourceType="cq/gui/components/authoring/dialog"
    extraClientlibs="[core.wcm.components.carousel.v1.editor]">

    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="cq/gui/components/authoring/dialog/panelcontainer"
        cq:panelContainer="true">

        <items jcr:primaryType="nt:unstructured">
            <carousel
                jcr:primaryType="nt:unstructured"
                sling:resourceType="core/wcm/components/carousel/v1/carousel/cq:dialog/content/items/carousel"/>
        </items>
    </content>
</jcr:root>
