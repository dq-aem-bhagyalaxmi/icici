                            jcr:lastModifiedBy="admin"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="icici/components/fixed-Deposit-Types-ChildComponent"
                            description="&lt;h3>Regular FD&lt;/h3>&#xd;&#xa;&lt;p>A safe and flexible investment product offering quarterly compounded interest.&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>&lt;p>Minimum deposit: Rs. 25,000&lt;/p>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;p>Flexible tenure: &lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>NRO - 7 days to 10 years&lt;/li>&#xd;&#xa;&lt;li>NRE - 1 year to 10 years&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;p>Open instantly via iMobile, Internet Banking, or any ICICI Bank branch.&lt;/p>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;p>Option for overdraft against FD and Premature /Partial withdrawals available.&lt;/p>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                            imageReference="/content/dam/icici/icici-images/regular-fixed-deposit-new.jpg"
                            textIsRich="[true,true]">
                            <buttonItems jcr:primaryType="nt:unstructured">
                                <item0
                                    jcr:primaryType="nt:unstructured"
                                    buttonLink="https://infinity.icicibank.com/corp/AuthenticationController?FORMSGROUP_ID__=AuthenticationFG&amp;__START_TRAN_FLAG__=Y&amp;FG_BUTTONS__=LOAD&amp;ACTION.LOAD=Y&amp;AuthenticationFG.LOGIN_FLAG=1&amp;BANK_ID=ICI&amp;CTA_FLAG=DEPOSIT&amp;af_xp=social&amp;source_caller=ui&amp;pid=RIB&amp;ITM=nli_cms_fd_menu_navigation&amp;utm_source=website&amp;shortlink=FDIndex&amp;utm_medium=onelink&amp;utm_campaign=fixeddeposit&amp;deep_link_value=openfdNew&amp;c=FD_RIB&amp;af_xp=social&amp;source_caller=ui&amp;pid=RIB&amp;ITM=nli_home_na_megamenuitem_1_cms_deposits_fixeddeposit_nli&amp;utm_source=website&amp;shortlink=FDIndex&amp;utm_medium=onelink&amp;utm_campaign=mrifixeddeposit&amp;deep_link_value=openfdNew&amp;c=FD_RIB"
                                    buttonText="&lt;p>INVEST NOW&lt;/p>&#xd;&#xa;"/>
                            </buttonItems>
                        </fixed_deposit_types_>
                    </item_1746597503909>
                    <item_1746597508995
                        cq:panelTitle="Tax Saver FD     "
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="icici/components/container">
